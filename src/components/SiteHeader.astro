---
import { SOCIAL } from "../lib/social";
---

<div class="topline"></div>
<header class="site-header">
  <nav class="nav container">
    <a href="/" class="wordmark">
      <span class="kicker">THE</span>
      Reed Vault<span class="dot">.</span>
    </a>
    <div class="nav-right">
      <span class="nav-social">
        <a href={SOCIAL.instagram} target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="3" width="18" height="18" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"></circle>
          </svg>
        </a>
        <a href={SOCIAL.youtube} target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round">
            <rect x="2.5" y="6" width="19" height="12" rx="3.6"></rect>
            <path d="M10.3 9.3 15 12 10.3 14.7Z" fill="currentColor" stroke="none"></path>
          </svg>
        </a>
      </span>
      <a href="/about/" class="nav-link">About Us</a>
      <a href="/vault/" class="nav-link nav-cta">Open the Vault →</a>
    </div>
  </nav>
</header>

<style>
  .topline {
    height: 3px;
    background: var(--reed-red);
  }

  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.1rem;
    padding-bottom: 1.1rem;
  }

  .wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.7rem;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .kicker {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    color: var(--meta);
    margin-bottom: 0.15rem;
  }

  .wordmark .dot {
    color: var(--reed-red);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-social {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding-right: 1.5rem;
    border-right: 1px solid var(--border);
  }

  .nav-social a {
    color: var(--ink);
    display: flex;
    transition: color var(--dur) var(--ease);
  }

  .nav-social a:hover {
    color: var(--reed-red);
  }

  .nav-social svg {
    width: 19px;
    height: 19px;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    color: var(--ink);
    background: none;
    border: none;
    padding: 0;
  }

  .nav-cta {
    color: var(--reed-red);
  }

  @media (max-width: 600px) {
    .nav-social {
      display: none;
    }
  }
</style>
