---
import { resizeImage, CATEGORY_BAND, CATEGORY_ICON, CATEGORY_SLUG, type Product, type Category } from "../lib/products";

interface Props {
  products: Product[];
}

const { products } = Astro.props;

const CATEGORY_ORDER: Category[] = ["Comics", "Trading Cards", "Memorabilia"];
const categories = CATEGORY_ORDER.map((category) => {
  const inCategory = products.filter((p) => p.category === category);
  const thumb = inCategory[0]?.images[0] ? resizeImage(inCategory[0].images[0], "s-l500") : null;
  return { category, count: inCategory.length, thumb, band: CATEGORY_BAND[category], icon: CATEGORY_ICON[category] };
});
---

<div class="cats">
  {
    categories.map(({ category, count, thumb, band, icon }) => (
      <a class="cattile" href={`/vault/?category=${CATEGORY_SLUG[category]}`} style={`border-top-color:${band.bg}`}>
        <div class="thumb">
          {thumb && <img src={thumb} alt="" loading="lazy" />}
        </div>
        <span class="icon" style={`color:${band.bg}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icon} />
        </span>
        <span class="label">
          <span class="name">{category}</span>
          <span class="count">
            {count} in the vault
          </span>
        </span>
        <span class="chevron">›</span>
      </a>
    ))
  }
</div>

<style>
  .cats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--grid-gap);
  }

  .cattile {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: 4px solid;
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: var(--ink);
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }

  .cattile:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .thumb {
    width: 52px;
    height: 52px;
    border-radius: var(--radius);
    background: var(--cream);
    overflow: hidden;
    flex-shrink: 0;
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .icon svg {
    width: 20px;
    height: 20px;
  }

  .label {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
  }

  .count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--meta);
  }

  .chevron {
    color: var(--meta);
    font-size: 1.1rem;
  }

  @media (max-width: 780px) {
    .cats {
      grid-template-columns: 1fr;
    }
  }
</style>
