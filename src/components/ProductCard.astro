---
import { resizeImage, formatPrice, itemPath, CATEGORY_BAND, CATEGORY_ICON, chipOf } from "../lib/products";
import type { Product } from "../lib/products";

interface Props {
  product: Product;
  priority?: boolean;
  graded?: "Graded" | "Ungraded";
}

const { product, priority = false, graded } = Astro.props;
const thumb = product.images[0] ? resizeImage(product.images[0], "s-l500") : null;
const band = CATEGORY_BAND[product.category];
const icon = CATEGORY_ICON[product.category];
const chip = chipOf(product);
---

<a
  class="card"
  href={itemPath(product.id)}
  data-specifics={JSON.stringify(product.specifics)}
  data-category={product.category}
  data-graded={graded}
  data-status={chip?.label ?? "Available"}
  data-search={`${product.title} ${product.category} ${product.condition ?? ""}`.toLowerCase()}
>
  <div class="band" style={`background:${band.bg};color:${band.fg}`}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icon} />
  </div>
  <div class="window">
    {chip && <span class="chip" style={`background:${chip.bg};color:${chip.fg}`}>{chip.label}</span>}
    {
      thumb && (
        <img
          src={thumb}
          width="500"
          height="500"
          alt={product.title}
          loading={priority ? "eager" : "lazy"}
          fetchpriority={priority ? "high" : "auto"}
        />
      )
    }
  </div>
  <div class="spec-strip">
    {product.condition && <p class="meta">{product.condition}</p>}
    <p class="title">{product.title}</p>
    <p class="price">{formatPrice(product.price, product.currency)}</p>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }

  .card:hover {
    transform: translateY(-3px);
  }

  .band {
    display: flex;
    padding: 0.4rem 0.6rem;
  }

  .band svg {
    width: 16px;
    height: 16px;
  }

  .window {
    position: relative;
    aspect-ratio: 1 / 1;
    background: #ffffff;
    overflow: hidden;
  }

  .window img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .chip {
    position: absolute;
    top: 10px;
    left: 10px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius);
  }

  .spec-strip {
    padding: 0.6rem 0.7rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .meta {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--meta);
  }

  .title {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .price {
    margin: 0.1rem 0 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    color: var(--reed-red);
  }
</style>
