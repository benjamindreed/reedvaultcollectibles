---
import { SOCIAL } from "../lib/social";
---

<footer class="site-footer">
  <div class="container footer-inner">
    <span class="legal">Reed Vault Collectibles LLC</span>
    <span class="social">
      <a href={SOCIAL.instagram} target="_blank" rel="noopener">Instagram</a>
      <a href={SOCIAL.youtube} target="_blank" rel="noopener">YouTube</a>
      <a href={SOCIAL.facebook} target="_blank" rel="noopener">Facebook</a>
    </span>
    <span class="tagline">Where the good stuff lives.</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 3rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--meta);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .social {
    display: flex;
    gap: 1.25rem;
  }

  .social a {
    color: var(--meta);
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }

  .social a:hover {
    color: var(--reed-red);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
