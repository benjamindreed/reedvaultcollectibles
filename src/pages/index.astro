---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import HeroCarousel from "../components/HeroCarousel.astro";
import CategoryShortcuts from "../components/CategoryShortcuts.astro";
import productsData from "../data/products.json";
import type { Product, Category } from "../lib/products";

const products = productsData as Product[];

const CATEGORY_ORDER: Category[] = ["Comics", "Trading Cards", "Memorabilia"];
const byRecency = (a: Product, b: Product) => new Date(b.createdAt ?? 0).getTime() - new Date(a.createdAt ?? 0).getTime();
const fresh = CATEGORY_ORDER.flatMap((category) =>
  products
    .filter((p) => p.category === category)
    .sort(byRecency)
    .slice(0, 4),
);

const EBAY_SELLER = "reedvault";
---

<BaseLayout
  title="Reed Vault Collectibles — Where the good stuff lives"
  description="A family-run online collectibles shop — comics, trading cards, memorabilia. Every listing answers what's fun about it before it says what a thing is worth."
  canonicalPath="/"
>
  <main class="container home">
    <HeroCarousel products={products} ebaySeller={EBAY_SELLER} />

    <CategoryShortcuts products={products} />
  </main>

  <section class="sec alt">
    <div class="container">
      <div class="rule"></div>
      <div class="sec-head">
        <h2>Fresh in the Vault</h2>
        <span class="count">{fresh.length} in view</span>
      </div>
      <div class="fresh-grid">
        {fresh.map((product, i) => <ProductCard product={product} priority={i < 4} />)}
      </div>
    </div>
  </section>

  <section class="fun">
    <div class="container">
      <div class="q">What's fun about it<span class="dot">?</span></div>
      <p class="s">
        We believe collecting should be fun. Every item answers this question, something a
        warehouse flipper never asks. That one sentence is our passion.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .home {
    padding-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .sec.alt {
    background: var(--cream);
    padding: 3rem 0;
  }

  .rule {
    width: 48px;
    height: 3px;
    background: var(--reed-red);
    margin-bottom: 1.25rem;
  }

  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .sec-head h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.6rem;
    margin: 0;
  }

  .sec-head .count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--meta);
  }

  .fresh-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--grid-gap);
  }

  .fun {
    padding: 5.25rem 0;
    text-align: center;
  }

  .fun .q {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 3.1rem;
    letter-spacing: -0.03em;
    line-height: 1.02;
    max-width: 820px;
    margin: 0 auto;
  }

  .fun .q .dot {
    color: var(--reed-red);
  }

  .fun .s {
    margin: 1.1rem auto 0;
    font-size: 1rem;
    color: var(--meta);
    max-width: 560px;
    line-height: 1.6;
  }

  @media (max-width: 780px) {
    .fresh-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .fun .q {
      font-size: 1.9rem;
    }
  }
</style>
